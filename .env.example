# Copy this file to .env and fill in real values.
# .env is read automatically by docker compose and substituted into
# docker-compose.yml. Do not commit the filled-in .env file.

HA_HOSTNAME=ha.example.com
HA_TOKEN=your-long-lived-access-token
HA_INPUT_ENTITY_ID=sensor.your_input_entity_id
HA_OUTPUT_ENTITY_ID=sensor.your_output_entity_id
